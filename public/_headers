/*
  Security & caching headers for Netlify (adjust as needed)
  - Protect against common attacks (CSP should be tightened for your site)
  - Enable long cache for static assets
*/

/*
  Enable strong security headers on all routes
*/
/*
  Content-Security-Policy left permissive for development; tighten for production.
*/
/*  All routes */
/* Set security headers */
/* Use a conservative CSP for initial deployment; replace with strict rules after testing */
/* Note: customize 'self' and add known CDNs if needed. */
/* CSP example below allows fonts, images, scripts from self and trusted sources. */

/* /  */
/:
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; font-src 'self' https: data:; connect-src 'self' https:; frame-ancestors 'none'
  Cache-Control: public, max-age=0, must-revalidate

# Static assets caching: cache hashed assets for long-term
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

/hero.avif
/hero.webp
  Cache-Control: public, max-age=31536000, immutable
